# Copy this to .env.local and fill in your values
# Never commit .env.local to git

# Neon database — get from your Neon project dashboard
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# App PIN — shared password to access the app (pick anything, e.g. "solstice2026")
APP_PIN="your-pin-here"

# JWT secret — run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-random-secret-here"
